# ============================================
# API KEY CONFIGURATION - FALLBACK STRATEGY
# ============================================
# Add multiple API keys to enable automatic fallback.
# If PRIMARY key hits rate limit or fails, system switches to SECONDARY, etc.

# Primary API Key (Required)
GEMINI_API_KEY=your_primary_gemini_api_key_here

# Secondary API Key (Optional - used if primary fails)
GEMINI_API_KEY_2=your_secondary_gemini_api_key_here

# Tertiary API Key (Optional - used if primary and secondary fail)
GEMINI_API_KEY_3=your_tertiary_gemini_api_key_here

# Quaternary API Key (Optional - used if all others fail)
GEMINI_API_KEY_4=your_quaternary_gemini_api_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=your_mongodb_connection_string
DATABASE_NAME=hackathon_db

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. Only GEMINI_API_KEY is required
# 2. Adding GEMINI_API_KEY_2/3/4 enables automatic fallback
# 3. System tracks failures and rotates between keys
# 4. Rate limit errors trigger automatic rotation
# 5. Failed keys enter cooldown (1 minute) before retry
